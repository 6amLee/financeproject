# Anthropic API key (from Ron)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Full Google service account JSON as a ONE-LINE string.
# This must be the Finance project's own service account — do NOT reuse Monica's.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"finance-bot@your-project.iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

# Master DB spreadsheet ID (the part of the sheet URL between /d/ and /edit)
GOOGLE_SHEETS_ID=your-master-db-spreadsheet-id

# Drive folder where receipt files are archived
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# Gmail label the intake watches (applied by a Gmail filter on finance@ mail)
GMAIL_WATCH_LABEL=Finance Stuff

# Gmail label applied once a message has been processed
GMAIL_PROCESSED_LABEL=Finance Processed

# How often to poll Gmail, in minutes
POLL_INTERVAL_MINUTES=5

# ── Olive (olive.js) — the statement-matching + Slack-chase service ──────────
# Finance's OWN Slack bot token (separate app from Monica's — see design doc
# open decision #3). Required unless running with --dry-run.
SLACK_BOT_TOKEN=xoxb-your-finance-bot-token

# Slack signing secret — from Slack App → Basic Information → App Credentials.
# Used to verify that interactive payloads (button clicks, modal submissions)
# really come from Slack and not an external caller.
SLACK_SIGNING_SECRET=your-slack-signing-secret

# The Slack channel ID for receipt uploads (private channel)
SLACK_INTAKE_CHANNEL=C0BFD8PJG3B

# How often Olive re-checks the statement + chase cadence, in minutes.
# Separate from POLL_INTERVAL_MINUTES: chase thresholds are 24h apart, so
# hourly (the default) is plenty.
OLIVE_POLL_INTERVAL_MINUTES=60

# ── Statement Comparison (statementOlive.js) ──────────────────────────────────
# Slack channel where Yulia uploads Bank Hapoalim Excel statements
SLACK_STATEMENTS_CHANNEL=C0XXXXXXXXX

# Slack channel for the Stage 3 company-wide blast (assertive public alert)
SLACK_COMPANY_CHANNEL=C0XXXXXXXXX

# Yulia's Slack user ID — used to DM her the final outstanding-charge summary
YULIA_SLACK_ID=U088YU5HD4H

# Finance admin's (Lee's) Slack user ID — the only other account, besides
# Yulia, allowed to ask Olive natural-language travel/cost questions in a DM
FINANCE_ADMIN_SLACK_ID=your-slack-user-id

# How often statementOlive polls for overdue chase threads, in minutes (default 60)
STATEMENT_OLIVE_POLL_MINUTES=60

# Optional: Gmail user to impersonate (service accounts need domain-wide
# delegation to read a user's mailbox — this is the mailbox that receives
# the finance@ group copies).
# GMAIL_IMPERSONATE_USER=lee@truvid.com
